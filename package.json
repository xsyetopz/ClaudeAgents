{
	"name": "olympi",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"biome:check": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
		"biome:check:fix": "bun run biome:check --write",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384",
		"biome:lint:fix": "bun run biome:lint --write",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun run olympi:test",
		"olympi": "bun packages/cli/src/cli.ts",
		"olympi:test": "bun test packages/cli/test/*.test.ts",
		"olympi:smoke": "bash scripts/ci-smoke.sh",
		"olympi:verify": "bun packages/cli/src/cli.ts verify",
		"olympi:catalog": "bun packages/cli/src/cli.ts catalog",
		"build": "bun run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"bun-types": "1.3.14"
	},
	"engines": {
		"node": ">=24.14.1"
	},
	"bin": {
		"olympi": "./packages/cli/src/cli.ts"
	}
}
