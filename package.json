{
	"name": "olympus",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"biome:check": "bunx biome check . --error-on-warnings --max-diagnostics 16384",
		"biome:check:fix": "bun run biome:check --write",
		"biome:lint": "bunx biome lint . --max-diagnostics 16384",
		"biome:lint:fix": "bun run biome:lint --write",
		"biome:format": "bunx biome format . --write --max-diagnostics 16384",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun run olympus:test",
		"olympus": "bun packages/olympus/src/cli.ts",
		"olympus:test": "bun test packages/olympus/test/*.test.ts",
		"olympus:verify": "bun packages/olympus/src/cli.ts verify",
		"olympus:catalog": "bun packages/olympus/src/cli.ts catalog"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"bun-types": "1.3.14"
	},
	"engines": {
		"node": ">=24.14.1"
	}
}
