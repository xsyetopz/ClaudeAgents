{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "rawShell",
    "runner",
    "destructiveCleanup",
    "evidenceId"
  ],
  "additionalProperties": false,
  "properties": {
    "rawShell": {
      "enum": [
        "approval-required"
      ]
    },
    "runner": {
      "enum": [
        "allowed"
      ]
    },
    "destructiveCleanup": {
      "enum": [
        "manifest-or-confirmed-only"
      ]
    },
    "evidenceId": {
      "type": "string"
    }
  }
}
