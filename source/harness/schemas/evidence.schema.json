{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "verifiedAt",
    "maxAgeDays",
    "platformEvidence",
    "requiredPlanPaths",
    "forbiddenActiveTerms",
    "requiredTerms"
  ],
  "additionalProperties": false,
  "properties": {
    "verifiedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "maxAgeDays": {
      "type": "integer",
      "minimum": 1
    },
    "platformEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platformId",
          "status",
          "evidenceType",
          "path",
          "verifiedAt"
        ],
        "additionalProperties": false,
        "properties": {
          "platformId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "sourced",
              "partial",
              "prompt-only",
              "unsupported",
              "UNKNOWN"
            ]
          },
          "evidenceType": {
            "enum": [
              "official-docs",
              "official-docs-and-runtime",
              "source",
              "runtime",
              "community",
              "UNKNOWN"
            ]
          },
          "path": {
            "type": "string"
          },
          "verifiedAt": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      }
    },
    "requiredPlanPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenActiveTerms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredTerms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
