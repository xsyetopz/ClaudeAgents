{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "ok",
    "passed",
    "failed",
    "failures"
  ],
  "additionalProperties": false,
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "failures": {
      "type": "array"
    }
  }
}
