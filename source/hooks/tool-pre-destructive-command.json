{
  "$schema": "../schema/hook.schema.json",
  "id": "tool-pre-destructive-command",
  "category": "tool-pre",
  "description": "Block destructive shell commands before tool execution.",
  "intent": "Prevent high-risk file, repository, and disk mutations from running without an explicit safer workflow.",
  "handler": {
    "kind": "command",
    "runtime_path": "source/hooks/runtime/tool-pre-destructive-command.mjs"
  },
  "supported_platforms": {
    "claude": {
      "events": [
        "PreToolUse"
      ],
      "input_adapter": "claude-pretooluse-shell",
      "output_adapter": "claude-block-or-allow",
      "matcher": "Bash",
      "timeout_seconds": 10
    },
    "codex": {
      "events": [
        "PreToolUse"
      ],
      "input_adapter": "codex-pretooluse-shell",
      "output_adapter": "codex-block-or-allow",
      "matcher": "^Bash$",
      "status_message": "Checking destructive shell policy",
      "timeout_seconds": 10
    }
  },
  "unsupported_platforms": {
    "opencode": "Hook payload parity not proven in this wave."
  }
}
