{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    }
  },
  "additionalProperties": {
    "$ref": "#/$defs/platformSubscription"
  },
  "required": [
    "codex",
    "claude"
  ],
  "$defs": {
    "platformSubscription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "allowed",
        "blocked",
        "source_urls"
      ],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "default": {
          "type": "string"
        },
        "allowed": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "blocked": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "source_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
