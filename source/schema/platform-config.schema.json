{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "platform",
    "binary",
    "schemas",
    "managed_keys"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "platform": {
      "enum": [
        "codex",
        "claude",
        "opencode",
        "kilo",
        "windsurf",
        "cline",
        "gemini",
        "cursor"
      ]
    },
    "binary": {
      "type": "string",
      "minLength": 1
    },
    "subscription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "allowed",
        "source_urls"
      ],
      "properties": {
        "default": {
          "type": "string"
        },
        "allowed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "blocked_consumer_tiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "schemas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "enum": [
          "codex_config",
          "claude_code_settings",
          "opencode_config"
        ]
      }
    },
    "required_config": {
      "type": "object"
    },
    "managed_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "profile_defaults": {
      "type": "object"
    },
    "route_defaults": {
      "type": "object"
    },
    "doctor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reject_when"
      ],
      "properties": {
        "reject_when": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
