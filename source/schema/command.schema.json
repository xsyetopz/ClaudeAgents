{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "description",
    "route"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "route": {
      "enum": [
        "plan",
        "research",
        "implement",
        "debug",
        "review",
        "utility",
        "classify_contract"
      ]
    }
  }
}
