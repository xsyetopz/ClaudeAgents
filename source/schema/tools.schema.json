{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tools"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "required",
          "probe",
          "install"
        ],
        "properties": {
          "required": {
            "type": "boolean"
          },
          "probe": {
            "type": "string",
            "minLength": 1
          },
          "install": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            },
            "required": [
              "macos",
              "linux"
            ]
          }
        }
      }
    }
  }
}
