{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fetched_at",
    "schemas"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "fetched_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "schemas": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/upstreamSchema"
      },
      "required": [
        "codex_config",
        "claude_code_settings",
        "opencode_config"
      ]
    }
  },
  "$defs": {
    "upstreamSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "local_cache",
        "sha256",
        "validates"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "local_cache": {
          "type": "string",
          "pattern": "^source/schemas/cache/.+\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "validates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
