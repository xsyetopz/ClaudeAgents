{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "description",
    "source",
    "body_path"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "body_path": {
      "type": "string",
      "pattern": "^source/skills/[a-z][a-z0-9-]*\\.md$"
    },
    "source": {
      "enum": [
        "local",
        "provider"
      ]
    },
    "provider": {
      "type": "string",
      "minLength": 1
    }
  }
}
