{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "description",
    "supported_platforms",
    "unsupported_platforms"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z]+-[a-z]+-.+"
    },
    "category": {
      "enum": [
        "tool-pre",
        "tool-post",
        "tool-fail",
        "prompt-submit",
        "session-start",
        "agent-start",
        "compact-pre"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "supported_platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "events",
          "input_adapter",
          "output_adapter"
        ],
        "properties": {
          "events": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "input_adapter": {
            "type": "string",
            "minLength": 1
          },
          "output_adapter": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unsupported_platforms": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
