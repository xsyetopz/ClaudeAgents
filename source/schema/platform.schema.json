{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "native_surfaces",
    "roots",
    "renderers"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "enum": [
        "codex",
        "claude",
        "opencode"
      ]
    },
    "native_surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "roots": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "global"
      ],
      "properties": {
        "project": {
          "type": "string",
          "minLength": 1
        },
        "global": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "renderers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
