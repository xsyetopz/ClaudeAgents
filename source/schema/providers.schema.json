{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "providers"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/provider"
      },
      "required": [
        "caveman",
        "rtk",
        "bmad-method",
        "taste-skill"
      ]
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "sync_mode",
        "default",
        "git",
        "upstream_path",
        "overlay_path",
        "provenance"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "sync_mode": {
          "enum": [
            "git-exact",
            "git-extract",
            "external-binary",
            "optional-cli"
          ]
        },
        "default": {
          "type": "string"
        },
        "probe": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "install": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "git": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repo_url",
            "remote",
            "branch",
            "locked_ref",
            "sync_strategy"
          ],
          "properties": {
            "repo_url": {
              "type": "string",
              "format": "uri"
            },
            "remote": {
              "type": "string",
              "minLength": 1
            },
            "branch": {
              "type": "string",
              "minLength": 1
            },
            "locked_ref": {
              "type": "string",
              "minLength": 1
            },
            "sync_strategy": {
              "enum": [
                "clone-fetch-checkout",
                "fetch-checkout",
                "probe-only"
              ]
            }
          }
        },
        "upstream_path": {
          "type": "string",
          "pattern": "^providers/[^/]+/upstream$"
        },
        "overlay_path": {
          "type": "string",
          "pattern": "^providers/[^/]+/overlay$"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "record_commit",
            "record_branch",
            "record_paths"
          ],
          "properties": {
            "record_commit": {
              "type": "boolean"
            },
            "record_branch": {
              "type": "boolean"
            },
            "record_paths": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
