{
  "$schema": "../schema/providers.schema.json",
  "providers": {
    "caveman": {
      "required": true,
      "sync_mode": "git-exact",
      "default": "sync-only",
      "git": {
        "repo_url": "https://github.com/juliusbrussee/caveman.git",
        "remote": "origin",
        "branch": "main",
        "locked_ref": "HEAD",
        "sync_strategy": "clone-fetch-checkout"
      },
      "upstream_path": "providers/caveman/upstream",
      "overlay_path": "providers/caveman/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    },
    "rtk": {
      "required": true,
      "sync_mode": "external-binary",
      "default": "external-binary",
      "probe": [
        "rtk --version",
        "rtk gain",
        "rtk rewrite <command>"
      ],
      "install": {
        "macos": [
          "brew install rtk-ai/tap/rtk"
        ],
        "linux": [
          "https://raw.githubusercontent.com/rtk-ai/rtk/main/install.sh"
        ]
      },
      "git": {
        "repo_url": "https://github.com/rtk-ai/rtk.git",
        "remote": "origin",
        "branch": "main",
        "locked_ref": "HEAD",
        "sync_strategy": "clone-fetch-checkout"
      },
      "upstream_path": "providers/rtk/upstream",
      "overlay_path": "providers/rtk/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    },
    "bmad-method": {
      "required": true,
      "sync_mode": "git-extract",
      "default": "sync-extract",
      "git": {
        "repo_url": "https://github.com/bmad-code-org/BMAD-METHOD.git",
        "remote": "origin",
        "branch": "main",
        "locked_ref": "HEAD",
        "sync_strategy": "clone-fetch-checkout"
      },
      "upstream_path": "providers/bmad-method/upstream",
      "overlay_path": "providers/bmad-method/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    },
    "taste-skill": {
      "required": true,
      "sync_mode": "git-exact",
      "default": "sync-only",
      "git": {
        "repo_url": "https://github.com/leonxlnx/taste-skill.git",
        "remote": "origin",
        "branch": "main",
        "locked_ref": "HEAD",
        "sync_strategy": "clone-fetch-checkout"
      },
      "upstream_path": "providers/taste-skill/upstream",
      "overlay_path": "providers/taste-skill/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    },
    "context7": {
      "required": false,
      "sync_mode": "optional-cli",
      "default": "cli-only",
      "probe": [
        "context7 --version",
        "ctx7 --version"
      ],
      "git": {
        "repo_url": "https://github.com/upstash/context7.git",
        "remote": "origin",
        "branch": "master",
        "locked_ref": "HEAD",
        "sync_strategy": "probe-only"
      },
      "upstream_path": "providers/context7/upstream",
      "overlay_path": "providers/context7/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    },
    "playwright-cli": {
      "required": false,
      "sync_mode": "optional-cli",
      "default": "cli-only",
      "probe": [
        "playwright-cli --help"
      ],
      "git": {
        "repo_url": "https://github.com/microsoft/playwright-cli.git",
        "remote": "origin",
        "branch": "main",
        "locked_ref": "HEAD",
        "sync_strategy": "probe-only"
      },
      "upstream_path": "providers/playwright-cli/upstream",
      "overlay_path": "providers/playwright-cli/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    },
    "deepwiki": {
      "required": false,
      "sync_mode": "optional-cli",
      "default": "cli-only",
      "probe": [
        "deepwiki --help"
      ],
      "git": {
        "repo_url": "https://www.deepwiki.sh/",
        "remote": "origin",
        "branch": "main",
        "locked_ref": "HEAD",
        "sync_strategy": "probe-only"
      },
      "upstream_path": "providers/deepwiki/upstream",
      "overlay_path": "providers/deepwiki/overlay",
      "provenance": {
        "record_commit": true,
        "record_branch": true,
        "record_paths": true
      }
    }
  }
}
