{
  "$schema": "../../schema/platform-config.schema.json",
  "platform": "codex",
  "binary": "codex",
  "subscription": {
    "default": "plus",
    "allowed": [
      "plus",
      "pro-5",
      "pro-20"
    ],
    "source_urls": [
      "https://help.openai.com/en/articles/11369540-codex-in-chatgpt",
      "https://help.openai.com/en/articles/6825453-chatgpt-rate-limits"
    ]
  },
  "schemas": {
    "generated_config": "codex_config"
  },
  "required_config": {
    "features": {
      "codex_hooks": true,
      "fast_mode": false,
      "multi_agent": false,
      "multi_agent_v2": true,
      "experimental_use_unified_exec_tool": false
    },
    "experimental_use_unified_exec_tool": false
  },
  "managed_keys": [
    "agents",
    "approval_policy",
    "features",
    "hooks",
    "marketplaces",
    "mcp_servers",
    "model",
    "model_reasoning_effort",
    "model_verbosity",
    "plugins",
    "profile",
    "profiles",
    "project_doc_max_bytes",
    "sandbox_mode",
    "skills",
    "tool_output_token_limit",
    "tools"
  ],
  "profile_defaults": {
    "plus": {
      "default": true,
      "agents": {
        "atalanta": {
          "model": "gpt-5.4-mini",
          "effort": "low"
        },
        "athena": {
          "model": "gpt-5.4-mini",
          "effort": "medium"
        },
        "calliope": {
          "model": "gpt-5.4-mini",
          "effort": "low"
        },
        "hephaestus": {
          "model": "gpt-5.3-codex",
          "effort": "medium"
        },
        "hermes": {
          "model": "gpt-5.4-mini",
          "effort": "low"
        },
        "nemesis": {
          "model": "gpt-5.5",
          "effort": "low"
        },
        "odysseus": {
          "model": "gpt-5.4",
          "effort": "low"
        }
      }
    },
    "pro-5": {
      "capacity_class": "pro-5",
      "agents": {
        "atalanta": {
          "model": "gpt-5.4-mini",
          "effort": "low"
        },
        "athena": {
          "model": "gpt-5.4",
          "effort": "medium"
        },
        "calliope": {
          "model": "gpt-5.4-mini",
          "effort": "low"
        },
        "hephaestus": {
          "model": "gpt-5.3-codex",
          "effort": "high"
        },
        "hermes": {
          "model": "gpt-5.4-mini",
          "effort": "low"
        },
        "nemesis": {
          "model": "gpt-5.5",
          "effort": "medium"
        },
        "odysseus": {
          "model": "gpt-5.4",
          "effort": "medium"
        }
      }
    },
    "pro-20": {
      "capacity_class": "pro-20",
      "agents": {
        "atalanta": {
          "model": "gpt-5.4-mini",
          "effort": "medium"
        },
        "athena": {
          "model": "gpt-5.4",
          "effort": "high"
        },
        "calliope": {
          "model": "gpt-5.4-mini",
          "effort": "medium"
        },
        "hephaestus": {
          "model": "gpt-5.3-codex",
          "effort": "high"
        },
        "hermes": {
          "model": "gpt-5.4-mini",
          "effort": "medium"
        },
        "nemesis": {
          "model": "gpt-5.5",
          "effort": "high"
        },
        "odysseus": {
          "model": "gpt-5.5",
          "effort": "medium"
        }
      }
    }
  },
  "doctor": {
    "reject_when": [
      "features.fast_mode == true",
      "features.unified_exec == true",
      "features.experimental_use_unified_exec_tool == true",
      "experimental_use_unified_exec_tool == true",
      "features.multi_agent == true",
      "subscription not in allowed"
    ]
  }
}
