{
  "$schema": "../../schema/platform-config.schema.json",
  "platform": "claude",
  "binary": "claude",
  "subscription": {
    "default": "max-5",
    "allowed": [
      "max-5",
      "max-20"
    ],
    "blocked_consumer_tiers": [
      "plus"
    ],
    "source_urls": [
      "https://support.claude.com/en/articles/11049741-what-is-the-max-plan"
    ]
  },
  "schemas": {
    "generated_settings": "claude_code_settings"
  },
  "managed_keys": [
    "agent",
    "allowManagedHooksOnly",
    "allowManagedMcpServersOnly",
    "allowManagedPermissionRulesOnly",
    "availableModels",
    "disableAllHooks",
    "fastMode",
    "fastModePerSessionOptIn",
    "hooks",
    "model",
    "modelOverrides",
    "permissions",
    "statusLine",
    "strictPluginOnlyCustomization"
  ],
  "required_config": {
    "disableAllHooks": false,
    "fastMode": false,
    "fastModePerSessionOptIn": false,
    "allowManagedHooksOnly": false,
    "allowManagedMcpServersOnly": false,
    "allowManagedPermissionRulesOnly": false
  },
  "profile_defaults": {
    "max-5": {
      "default": true,
      "agents": {
        "atalanta": {
          "model": "claude-haiku-4-5",
          "effort": "low"
        },
        "athena": {
          "model": "claude-sonnet-4-6",
          "effort": "medium"
        },
        "calliope": {
          "model": "claude-haiku-4-5",
          "effort": "low"
        },
        "hephaestus": {
          "model": "claude-sonnet-4-6",
          "effort": "high"
        },
        "hermes": {
          "model": "claude-haiku-4-5",
          "effort": "low"
        },
        "nemesis": {
          "model": "claude-opus-4-7",
          "effort": "medium"
        },
        "odysseus": {
          "model": "claude-sonnet-4-6",
          "effort": "medium"
        }
      }
    },
    "max-20": {
      "capacity_class": "max-20",
      "agents": {
        "atalanta": {
          "model": "claude-haiku-4-5",
          "effort": "medium"
        },
        "athena": {
          "model": "claude-opus-4-7",
          "effort": "high"
        },
        "calliope": {
          "model": "claude-haiku-4-5",
          "effort": "medium"
        },
        "hephaestus": {
          "model": "claude-sonnet-4-6",
          "effort": "high"
        },
        "hermes": {
          "model": "claude-haiku-4-5",
          "effort": "medium"
        },
        "nemesis": {
          "model": "claude-opus-4-7",
          "effort": "high"
        },
        "odysseus": {
          "model": "claude-opus-4-7",
          "effort": "medium"
        }
      }
    }
  },
  "doctor": {
    "reject_when": [
      "subscription == plus",
      "subscription not in allowed",
      "disableAllHooks == true",
      "fastMode == true",
      "fastModePerSessionOptIn == true"
    ]
  }
}
